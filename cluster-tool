def cmd_destroy(args):
    state = load_state()
    if args.all:
        ids = list(state["clones"].keys())
        if not ids:
            print("No clones to destroy.")
            return
    elif args.name:
        ids = [args.name]
    else:
        sys.exit("Specify a clone name or --all")

    for cid in ids:
        vm = f"test-infra-cluster-{cid}-master-0"
        print(f'Destroying clone "{cid}"...')

        destroy_vm(vm)
        env.run(f"virsh net-destroy test-infra-net-{cid}", check=False)
        env.run(f"virsh net-undefine test-infra-net-{cid}", check=False)
        env.run(f"virsh net-destroy test-infra-secondary-network-{cid}", check=False)
        env.run(f"virsh net-undefine test-infra-secondary-network-{cid}", check=False)
        env.run(f"bash -c 'rm -f {REMOTE_OVERLAYS}/{cid}-*.qcow2'")

        remove_haproxy_clone(cid)
        remove_dns_entry(cid)
        (KUBECONFIG_DIR / f"{cid}.kubeconfig").unlink(missing_ok=True)

        with locked_state() as s:
            s["clones"].pop(cid, None)
        print(f'Clone "{cid}" destroyed.')


def cmd_push(args):
    state = load_state()
    flavor_name = args.name
    if flavor_name not in state["flavors"]:
        sys.exit(f"Flavor '{flavor_name}' not found. Available: {', '.join(state['flavors'].keys())}")

    for tool in ("pigz", "podman", "split"):
        r = env.run(f"command -v {tool}", check=False)
        if r.returncode != 0:
            sys.exit(f"Required tool '{tool}' not found on PATH")

    flavor = state["flavors"][flavor_name]
    disk_names = flavor["disks"]
    fdir = flavor_dir(flavor_name)
    crypto = flavor_crypto_dir(flavor_name)
    image_ref = f"{args.registry}:{args.tag}"
    tmp = f"{REMOTE_BASE}/tmp-push-{flavor_name}"

    total = 8
    print(f"Pushing flavor '{flavor_name}' to {image_ref}...")
    try:
        print_step(1, total, "Creating temp directory")
        env.run(f"mkdir -p {tmp}/chunks {tmp}/crypto")
        print_step(1, total, "Creating temp directory", "done")

        print_step(2, total, f"Splitting {len(disk_names)} disk(s)")
        for disk_name in disk_names:
            prefix = disk_name.replace(".qcow2", "")
            env.run(f"split -b 1G {fdir}/{disk_name} {tmp}/chunks/{prefix}.chunk.")
        print_step(2, total, f"Splitting {len(disk_names)} disk(s)", "done")

        print_step(3, total, "Compressing chunks")
        env.run(f"pigz {tmp}/chunks/*.chunk.*")
        print_step(3, total, "Compressing chunks", "done")

        print_step(4, total, "Copying crypto")
        env.run(f"cp -r {crypto}/* {tmp}/crypto/")
        print_step(4, total, "Copying crypto", "done")

        print_step(5, total, "Writing manifest")
        metadata = {k: v for k, v in flavor.items() if k != "disks"}
        manifest = build_manifest(flavor_name=flavor_name, metadata=metadata, disk_names=disk_names)
        env.write_file(f"{tmp}/manifest.json", json.dumps(manifest, indent=2))
        print_step(5, total, "Writing manifest", "done")

        print_step(6, total, "Generating Dockerfile")
        r = env.run(f"ls -1 {tmp}/chunks/ | sort")
        chunk_files = [f for f in r.stdout.strip().split("\n") if f]
        lines = ["FROM scratch"]
        lines.append(f"COPY manifest.json /manifest.json")
        lines.append(f"COPY crypto/ /crypto/")
        for chunk in chunk_files:
            lines.append(f"COPY chunks/{chunk} /chunks/{chunk}")
        env.write_file(f"{tmp}/Dockerfile", "\n".join(lines) + "\n")
        print_step(6, total, "Generating Dockerfile", "done")

        print_step(7, total, "Building image")
        env.run(f"{podman(f'build -t {image_ref} {tmp}/')}")
        print_step(7, total, "Building image", "done")

        print_step(8, total, "Pushing image")
        env.run(f"{podman(f'push {image_ref}')}")
        print_step(8, total, "Pushing image", "done")

    finally:
        env.run(f"rm -rf {tmp}", check=False)

    print(f"\nPushed: {image_ref}")


def cmd_pull(args):
    image_ref = args.image

    for tool in ("pigz", "podman"):
        r = env.run(f"command -v {tool}", check=False)
        if r.returncode != 0:
            sys.exit(f"Required tool '{tool}' not found on PATH")

    container_name = f"cluster-tool-pull-{os.getpid()}"
    tmp = f"{REMOTE_BASE}/tmp-pull-{os.getpid()}"
    total = 8
    print(f"Pulling from {image_ref}...")

    try:
        print_step(1, total, "Pulling image")
        env.run(f"{podman(f'pull {image_ref}')}")
        print_step(1, total, "Pulling image", "done")

        print_step(2, total, "Extracting contents")
        env.run(f"{podman(f'create --name {container_name} {image_ref}')}")
        env.run(f"mkdir -p {tmp}")
        env.run(f"{podman(f'cp {container_name}:/ {tmp}/')}")
        env.run(f"{podman(f'rm {container_name}')}")
        print_step(2, total, "Extracting contents", "done")

        print_step(3, total, "Reading manifest")
        r = env.run(f"cat {tmp}/manifest.json")
        manifest = parse_manifest(r.stdout)
        print_step(3, total, "Reading manifest", "done")

        flavor_name = args.name or manifest["flavor"]
        state = load_state()
        if flavor_name in state["flavors"]:
            sys.exit(f"Flavor '{flavor_name}' already exists. Delete it first with 'cluster-tool flavors --delete {flavor_name}'.")

        fdir = flavor_dir(flavor_name)
        crypto = flavor_crypto_dir(flavor_name)

        print_step(4, total, "Decompressing chunks")
        env.run(f"ls {tmp}/chunks/*.gz | xargs -P 16 -I{{}} pigz -d {{}}")
        print_step(4, total, "Decompressing chunks", "done")

        print_step(5, total, "Creating flavor directory")
        env.run(f"mkdir -p {fdir}")
        print_step(5, total, "Creating flavor directory", "done")

        print_step(6, total, f"Reassembling {len(manifest['disks'])} disk(s)")
        for disk in manifest["disks"]:
            env.run(f"cat {tmp}/chunks/{disk['prefix']}.chunk.* > {fdir}/{disk['name']}")
            env.run(f"chown qemu:qemu {fdir}/{disk['name']}")
        print_step(6, total, f"Reassembling {len(manifest['disks'])} disk(s)", "done")

        print_step(7, total, "Installing crypto")
        env.run(f"mkdir -p {crypto}")
        env.run(f"cp -r {tmp}/crypto/* {crypto}/")
        print_step(7, total, "Installing crypto", "done")

        print_step(8, total, "Registering flavor")
        metadata = manifest["metadata"]
        disk_names = [d["name"] for d in manifest["disks"]]
        with locked_state() as state:
            state["flavors"][flavor_name] = {
                **metadata,
                "disks": disk_names,
            }
        print_step(8, total, "Registering flavor", "done")

    finally:
        env.run(f"rm -rf {tmp}", check=False)
        env.run(f"{podman(f'rm {container_name}')}", check=False)
        env.run(f"{podman(f'rmi {image_ref}')}", check=False)

    print(f"\nFlavor '{flavor_name}' pulled and registered at {fdir}")


def cmd_setup(args):
    _setup_client()


def _setup_client():
    if os.geteuid() != 0:
        sys.exit("Run with sudo: sudo ./cluster-tool setup client")

    user = os.environ.get("SUDO_USER", "root")

    print("=== cluster-tool client setup ===")

    print("[1/6] Installing dnsmasq...")
    subprocess.run(["dnf", "install", "-y", "dnsmasq"], capture_output=True, check=True)

    print("[2/6] Enabling dnsmasq in NetworkManager...")
    Path("/etc/NetworkManager/conf.d").mkdir(parents=True, exist_ok=True)
    Path("/etc/NetworkManager/conf.d/cluster-tool-dns.conf").write_text("[main]\ndns=dnsmasq\n")

    print("[3/6] Making dnsmasq config dir writable...")
    DNSMASQ_DIR.mkdir(parents=True, exist_ok=True)
    subprocess.run(["chown", user, str(DNSMASQ_DIR)], check=True)

    print("[4/6] Adding polkit rule for NetworkManager reload...")
    Path("/etc/polkit-1/rules.d").mkdir(parents=True, exist_ok=True)
    Path("/etc/polkit-1/rules.d/50-cluster-tool-nm.rules").write_text(
        f'polkit.addRule(function(action, subject) {{\n'
        f'    if (action.id == "org.freedesktop.NetworkManager.reload" &&\n'
        f'        subject.user == "{user}") {{\n'
        f'        return polkit.Result.YES;\n'
        f'    }}\n'
        f'}});\n'
    )

    print("[5/6] Stopping stale dnsmasq processes...")
    subprocess.run(["pkill", "-x", "dnsmasq"], capture_output=True)
    time.sleep(1)

    print("[6/6] Restarting NetworkManager...")
    resolv = Path("/etc/resolv.conf")
    if resolv.is_symlink():
        resolv.unlink()
    subprocess.run(["systemctl", "restart", "NetworkManager"], check=True)

    for _ in range(30):
        if resolv.exists() and "127.0.0.1" in resolv.read_text():
            print("  resolv.conf: OK (nameserver 127.0.0.1)")
            break
        time.sleep(0.5)
    else:
        sys.exit("  resolv.conf: FAILED (expected nameserver 127.0.0.1 after 15s)")

    r = subprocess.run(["su", "-", user, "-c", "nmcli general reload"], capture_output=True)
    if r.returncode == 0:
        print("  nmcli reload: OK (no sudo needed)")
    else:
        sys.exit("  nmcli reload: FAILED (polkit rule not working)")

    print("\nClient setup complete.")


def _setup_server(*, data_path=None):
    env.run("test $(id -u) -eq 0", check=True)
    print("=== cluster-tool server setup ===")

    print("[1/6] Installing packages...")
    env.run("dnf install -y libvirt qemu-kvm podman pigz haproxy")

    print("[2/6] Enabling services...")
    env.run("systemctl enable --now libvirtd")
    r = env.run("grep -q 'default_backend api-' /etc/haproxy/haproxy.cfg 2>/dev/null", check=False)
    if r.returncode != 0:
        env.write_file("/etc/haproxy/haproxy.cfg", HAPROXY_BASE_CONFIG)
    env.run("setsebool -P haproxy_connect_any 1")
    env.run("if systemctl is-active firewalld &>/dev/null; then "
            "firewall-cmd --permanent --add-port=6443/tcp --add-port=443/tcp --add-port=80/tcp && "
            "firewall-cmd --reload; fi")
    env.run("systemctl enable --now haproxy")
    env.run("systemctl restart haproxy")

    print("[3/6] Generating SSH keypair...")
    env.run("test -f ~/.config/cluster-tool/cluster-tool.key || "
            "ssh-keygen -t ed25519 -f ~/.config/cluster-tool/cluster-tool.key -N '' -q")

    print("[4/6] Configuring podman parallel downloads...")
    env.run("mkdir -p ~/.config/containers")
    env.run("test -f ~/.config/containers/containers.conf || "
            "echo -e '[engine]\\nimage_parallel_copies = 20' > ~/.config/containers/containers.conf")

    print("[5/6] Configuring data directory...")
    r = env.run("cat ~/.config/cluster-tool/config", check=False)
    if r.returncode == 0:
        for line in r.stdout.strip().split("\n"):
            if line.startswith("CLUSTER_TOOL_DATA="):
                data_path = line.split("=", 1)[1]
        print(f"  Config already exists, using: {data_path}")
    else:
        if not data_path:
            r2 = env.run("df --output=avail,target -x tmpfs -x devtmpfs | tail -n +2 | sort -rn | head -1 | awk '{print $2}'")
            largest = r2.stdout.strip()
            suggested = f"{largest}/cluster-tool"
            print(f"  Largest partition: {largest}")
            print(f"  Suggested data path: {suggested}")
            user_path = input(f"  Data path [{suggested}]: ").strip()
            data_path = user_path or suggested
        env.run(f"mkdir -p ~/.config/cluster-tool")
        env.run(f"echo 'CLUSTER_TOOL_DATA={data_path}' > ~/.config/cluster-tool/config")
        print(f"  Data path: {data_path}")

    env.run(f"mkdir -p {data_path}/flavors {data_path}/overlays {data_path}/tmp {data_path}/containers/storage")

    print("[6/6] Verifying...")
    env.run("virsh version | head -1")
    env.run("podman --version")
    env.run("pigz --version")
    r = env.run(f"df -h {data_path} | tail -1 | awk '{{print $4}}'")
    print(f"  Storage available: {r.stdout.strip()}")
    print("\nServer setup complete.")


def cmd_connect(args):
    global env
    host = args.host
    hostname = socket.gethostname() if host == "local" else host.split("@")[-1]
    try:
        host_ip = socket.getaddrinfo(hostname, None)[0][4][0]
    except socket.gaierror:
        sys.exit(f"Cannot resolve hostname '{hostname}'.")
    env = ExecutionEnv(host=host, host_ip=host_ip)
    _setup_server(data_path=args.data_path)
    config = load_servers()
    config["servers"][args.name] = {"host": host}
    if config["default"] is None:
        config["default"] = args.name
    save_servers(config)
    print(f"\nServer '{args.name}' connected and registered.")


def cmd_servers(args):
    config = load_servers()
    if not config["servers"]:
        print("No servers connected. Run './cluster-tool connect NAME --host ...' to add one.")
        return
    default = config.get("default")
    print(f"{'NAME':<20s} {'HOST':<60s} DEFAULT")
    print("-" * 90)
    for name, info in config["servers"].items():
        marker = "*" if name == default else ""
        print(f"{name:<20s} {info['host']:<60s} {marker}")


def cmd_use(args):
    config = load_servers()
    if args.name not in config["servers"]:
        sys.exit(f"Server '{args.name}' not found.")
    config["default"] = args.name
    save_servers(config)
    print(f"Default server set to '{args.name}'.")


def main():
    global env

    parser = argparse.ArgumentParser(description="Snapshot-based SNO cluster cloning")
    sub = parser.add_subparsers(dest="command")

    snap_p = sub.add_parser("snapshot", help="Create a named snapshot flavor from a running cluster")
    snap_p.add_argument("--name", required=True, help="Flavor name (e.g., sno-64, sno-cnv)")
    snap_p.add_argument("--source", required=True, help="Source cluster ID (8 hex chars from VM name)")

    boot_p = sub.add_parser("boot", help="Boot a fresh cluster from a snapshot flavor")
    boot_p.add_argument("--flavor", help="Flavor to boot from (default: most recent)")
    boot_p.add_argument("--name", help="Clone ID (random if omitted)")

    list_p = sub.add_parser("list", help="Show running clones")

    flavors_p = sub.add_parser("flavors", help="List or manage snapshot flavors")
    flavors_p.add_argument("--delete", metavar="NAME", help="Delete a flavor")

    verify_p = sub.add_parser("verify", help="Run smoke tests on a clone")
    verify_p.add_argument("name", help="Clone ID to verify")

    destroy_p = sub.add_parser("destroy", help="Tear down a clone")
    destroy_p.add_argument("name", nargs="?", help="Clone ID to destroy")
    destroy_p.add_argument("--all", action="store_true", help="Destroy all clones")

    push_p = sub.add_parser("push", help="Push a flavor to an OCI registry")
    push_p.add_argument("name", help="Flavor name to push")
    push_p.add_argument("--registry", required=True, help="Registry repo (e.g., quay.io/org/repo)")
    push_p.add_argument("--tag", required=True, help="Image tag (e.g., sno-cnv, osac-v4.20)")

    pull_p = sub.add_parser("pull", help="Pull a flavor from an OCI registry")
    pull_p.add_argument("image", help="Full image reference (e.g., quay.io/org/repo:tag)")
    pull_p.add_argument("--name", help="Local flavor name (default: from manifest)")

    setup_p = sub.add_parser("setup", help="One-time client setup")
    setup_p.add_argument("mode", choices=["client"], help="'client' for DNS setup")

    connect_p = sub.add_parser("connect", help="Connect to a baremetal server")
    connect_p.add_argument("name", help="Alias for this server")
    connect_p.add_argument("--host", required=True, help="SSH target (e.g., root@hostname) or 'local'")
    connect_p.add_argument("--data-path", help="Data directory (auto-detected if omitted)")

    sub.add_parser("servers", help="List connected servers")

    use_p = sub.add_parser("use", help="Set default server")
    use_p.add_argument("name", help="Server alias to set as default")

    for p in [snap_p, boot_p, list_p, flavors_p, verify_p, destroy_p, push_p, pull_p]:
        p.add_argument("--server", help="Server alias (default: from config)")

    args = parser.parse_args()
    cmds = {"snapshot": cmd_snapshot, "boot": cmd_boot, "list": cmd_list, "flavors": cmd_flavors, "verify": cmd_verify, "destroy": cmd_destroy, "push": cmd_push, "pull": cmd_pull}

    if args.command == "setup":
        cmd_setup(args)
        return
    if args.command == "servers":
        cmd_servers(args)
        return
    if args.command == "use":
        cmd_use(args)
        return
    if args.command == "connect":
        cmd_connect(args)
        return
    if args.command not in cmds:
        parser.print_help()
        sys.exit(1)

    server_name = getattr(args, "server", None) or os.environ.get("CLUSTER_TOOL_HOST")
    if not server_name:
        config = load_servers()
        server_name = config.get("default")
    if not server_name:
        sys.exit("No server specified. Use --server NAME, or set a default with './cluster-tool use NAME'.")

    if "@" in server_name or server_name == "local":
        host = server_name
    else:
        host = resolve_server(server_name)

    hostname = socket.gethostname() if host == "local" else host.split("@")[-1]
    try:
        host_ip = socket.getaddrinfo(hostname, None)[0][4][0]
    except socket.gaierror:
        sys.exit(f"Cannot resolve hostname '{hostname}'.")
    env = ExecutionEnv(host=host, host_ip=host_ip)

    r = env.run("cat ~/.config/cluster-tool/config", check=False)
    if r.returncode != 0:
        sys.exit(f"Server not set up. Run './cluster-tool connect {server_name} --host ...' first.")
    for line in r.stdout.strip().split("\n"):
        if line.startswith("CLUSTER_TOOL_DATA="):
            _init_paths(line.split("=", 1)[1])
            break

    cmds[args.command](args)


if __name__ == "__main__":
    main()
