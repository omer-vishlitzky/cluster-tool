    env.run(f"mkdir -p {SERVER_CONFIG_DIR}")
    env.write_file(SERVER_STATE_FILE, json.dumps(state, indent=2) + "\n")


@contextmanager
def locked_state():
    CLIENT_CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    lock_path = CLIENT_CONFIG_DIR / "state.lock"
    with open(lock_path, "w") as lock_fd:
        fcntl.flock(lock_fd, fcntl.LOCK_EX)
        state = load_state()
        yield state
        save_state(state)


@contextmanager
def locked_haproxy():
    CLIENT_CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    lock_path = CLIENT_CONFIG_DIR / "haproxy.lock"
    with open(lock_path, "w") as lock_fd:
        fcntl.flock(lock_fd, fcntl.LOCK_EX)
        yield


