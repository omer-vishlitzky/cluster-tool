def gen_vm_xml(clone_id, overlay_disks, mac_primary, mac_secondary, memory_kib=67108864, vcpus=16):
    if isinstance(overlay_disks, str):
        overlay_disks = [overlay_disks]
    disk_xml = ""
    for i, overlay in enumerate(overlay_disks):
        dev = f"sd{chr(97 + i)}"
        disk_xml += (
            f"\n            <disk type='file' device='disk'>"
            f"\n              <driver name='qemu' type='qcow2'/>"
            f"\n              <source file='{overlay}'/>"
            f"\n              <target dev='{dev}' bus='scsi'/>"
            f"\n            </disk>")
    return textwrap.dedent(f"""\
        <domain type='kvm'>
          <name>test-infra-cluster-{clone_id}-master-0</name>
          <memory unit='KiB'>{memory_kib}</memory>
          <currentMemory unit='KiB'>{memory_kib}</currentMemory>
          <vcpu placement='static'>{vcpus}</vcpu>
          <os>
            <type arch='x86_64' machine='pc-i440fx-rhel7.6.0'>hvm</type>
            <boot dev='hd'/>
          </os>
          <features><acpi/><apic/><pae/></features>
          <cpu mode='host-passthrough' check='none' migratable='on'/>
          <clock offset='utc'/>
          <on_poweroff>destroy</on_poweroff>
          <on_reboot>restart</on_reboot>
          <on_crash>destroy</on_crash>
          <devices>
            <emulator>/usr/libexec/qemu-kvm</emulator>{disk_xml}
            <controller type='scsi' index='0' model='virtio-scsi'/>
            <interface type='network'>
              <mac address='{mac_primary}'/>
              <source network='test-infra-net-{clone_id}'/>
              <model type='virtio'/>
            </interface>
            <interface type='network'>
              <mac address='{mac_secondary}'/>
              <source network='test-infra-secondary-network-{clone_id}'/>
              <model type='virtio'/>
            </interface>
            <serial type='pty'><target port='0'/></serial>
            <console type='pty'><target type='serial' port='0'/></console>
          </devices>
        </domain>""")


def gen_haproxy_additions(clone_id, subnet):
    ip = f"192.168.{subnet}.{VM_IP_SUFFIX}"
    domain = f"test-infra-cluster-{clone_id}.redhat.com"
    use_backends = {
        "api": f"    use_backend api-{clone_id} if {{ req_ssl_sni -m end {domain} }}",
        "ingress-https": f"    use_backend ingress-https-{clone_id} if {{ req_ssl_sni -m end {domain} }}",
        "ingress-http": f"    use_backend ingress-http-{clone_id} if {{ hdr_end(host) {domain} }}",
    }
    backends = (
        f"\nbackend api-{clone_id}\n"
        f"    server api {ip}:6443 check\n"
        f"\nbackend ingress-https-{clone_id}\n"
        f"    server ingress {ip}:443 check\n"
        f"\nbackend ingress-http-{clone_id}\n"
        f"    mode http\n"
        f"    server ingress {ip}:80 check\n"
    )
    return use_backends, backends


def gen_dnsmasq_conf(clone_id):
    domain = f"test-infra-cluster-{clone_id}.redhat.com"
    return f"address=/{domain}/{BAREMETAL_IP}\n"


def print_step(num, total, desc, status=""):
    if status:
        print(f"\r  [{num}/{total}] {desc:<40s} {status}")
    else:
        print(f"  [{num}/{total}] {desc:<40s}", end="", flush=True)


def ssh_baremetal(cmd, check=True):
    r = subprocess.run(
        ["ssh"] + SSH_OPTS + [BAREMETAL_HOST, cmd],
        capture_output=True, text=True,
    )
    if check and r.returncode != 0:
        sys.exit(f"SSH command failed (exit {r.returncode}): {cmd}\n{r.stderr.strip()}")
    return r


def ssh_vm(vm_ip, cmd, check=True):
    jump = f"ssh {' '.join(SSH_OPTS)} core@{vm_ip} '{cmd}'"
    return ssh_baremetal(jump, check=check)


def scp_from_baremetal(remote_path, local_path):
    subprocess.run(
        ["scp"] + SSH_OPTS + [f"{BAREMETAL_HOST}:{remote_path}", str(local_path)],
        capture_output=True, text=True, check=True,
    )


def write_remote_file(path, content):
    encoded = base64.b64encode(content.encode()).decode()
    ssh_baremetal(f"echo '{encoded}' | base64 -d > {path}")


def destroy_vm(vm_name):
    r = ssh_baremetal(f"virsh domstate {vm_name}", check=False)
    if r.returncode != 0:
        return
    if "shut off" in r.stdout:
        ssh_baremetal(f"virsh undefine {vm_name}")
        return
    ssh_baremetal(f"virsh destroy {vm_name}")
    ssh_baremetal(f"virsh undefine {vm_name}")


def add_haproxy_clone(clone_id, subnet):
    with locked_haproxy():
        use_backends, backends = gen_haproxy_additions(clone_id, subnet)
        result = ssh_baremetal("cat /etc/haproxy/haproxy.cfg")
        config = result.stdout

        for key in ["api", "ingress-https", "ingress-http"]:
            marker = f"    default_backend {key}-"
            config = config.replace(marker, f"{use_backends[key]}\n\n{marker}", 1)

        config = config.rstrip() + "\n" + backends
        write_remote_file("/etc/haproxy/haproxy.cfg", config)
        ssh_baremetal("systemctl reload haproxy")


def remove_haproxy_clone(clone_id):
    with locked_haproxy():
        result = ssh_baremetal("cat /etc/haproxy/haproxy.cfg")
        lines = result.stdout.split("\n")
        filtered = []
        skip_block = False
        for line in lines:
            if f"use_backend" in line and f"-{clone_id}" in line:
                continue
            if line.strip().startswith("backend") and f"-{clone_id}" in line:
                skip_block = True
                continue
            if skip_block:
                if line.strip() and not line.strip().startswith("backend") and not line.strip().startswith("frontend"):
                    continue
                skip_block = False
                if not line.strip():
                    continue
            filtered.append(line)
        write_remote_file("/etc/haproxy/haproxy.cfg", "\n".join(filtered))
        ssh_baremetal("systemctl reload haproxy")


def add_dns_entry(clone_id):
    conf = DNSMASQ_DIR / f"cluster-{clone_id}.conf"
    conf.write_text(gen_dnsmasq_conf(clone_id))
    subprocess.run(["nmcli", "general", "reload"], check=True)


def remove_dns_entry(clone_id):
    conf = DNSMASQ_DIR / f"cluster-{clone_id}.conf"
    conf.unlink(missing_ok=True)
    subprocess.run(["nmcli", "general", "reload"], check=True)


def verify_cluster_identity(vm_ip, expected_id, expected_domain):
    kc = "/etc/kubernetes/static-pod-resources/kube-apiserver-certs/secrets/node-kubeconfigs/lb-ext.kubeconfig"
    r = ssh_vm(vm_ip,
        f"sudo oc --kubeconfig={kc} --insecure-skip-tls-verify "
        f"get infrastructure cluster "
        f'-o jsonpath="{{.status.apiServerURL}}"')
    api_url = r.stdout.strip()
    if expected_domain not in api_url:
        sys.exit(
            f"IDENTITY MISMATCH: apiServerURL is '{api_url}' but expected domain '{expected_domain}'. "
            f"Recert may have failed to update the infrastructure resource. "
            f"Aborting to prevent source cluster corruption."
        )


def cmd_snapshot(args):
    state = load_state()
    flavor_name = args.name
    source_id = args.source

    if flavor_name in state["flavors"]:
        sys.exit(f"Flavor '{flavor_name}' already exists. Delete it first with 'cluster-tool flavors --delete {flavor_name}'.")

    vm_name = f"test-infra-cluster-{source_id}-master-0"
    fdir = flavor_dir(flavor_name)
    crypto = flavor_crypto_dir(flavor_name)

    r = ssh_baremetal(f"virsh dominfo {vm_name}")
    dominfo = parse_dominfo(r.stdout)

    r = ssh_baremetal(f"virsh dumpxml {vm_name}")
    disks = parse_disk_paths(r.stdout, f"test-infra-cluster-{source_id}")

    r = ssh_baremetal(f"virsh net-dumpxml test-infra-net-{source_id}")
    src_primary_subnet = parse_subnet(r.stdout)
    r = ssh_baremetal(f"virsh net-dumpxml test-infra-secondary-network-{source_id}")
    src_secondary_subnet = parse_subnet(r.stdout)

    vm_ip = f"192.168.{src_primary_subnet}.{VM_IP_SUFFIX}"

    r = ssh_baremetal(f"virsh domstate {vm_name}")
    vm_state = r.stdout.strip()
    if vm_state != "running":
        sys.exit(f"Source VM '{vm_name}' is '{vm_state}', expected 'running'")

    print(f"Creating snapshot flavor '{flavor_name}' from {vm_name}...")

    print_step(1, 6, "Detecting etcd image")
    etcd_r = ssh_vm(vm_ip,
        "sudo python3 -c \""
        "import json; "
        "d=json.load(open('/etc/kubernetes/manifests/etcd-pod.yaml')); "
        "print(next(c['image'] for c in d['spec']['containers'] if c['name']=='etcd'))\"",
        check=False)
    etcd_image = etcd_r.stdout.strip() if etcd_r.returncode == 0 and etcd_r.stdout.strip() else ETCD_IMAGE
    print_step(1, 6, "Detecting etcd image", "done")

    print_step(2, 6, "Extracting crypto keys")
    node_kc = "/etc/kubernetes/static-pod-resources/kube-apiserver-certs/secrets/node-kubeconfigs/lb-ext.kubeconfig"
    temp_kc = f"/tmp/kubeconfig-{source_id}"
    ssh_baremetal(f"ssh {' '.join(SSH_OPTS)} core@{vm_ip} 'sudo cat {node_kc}' > {temp_kc}")
    oc = f"KUBECONFIG={temp_kc} oc --insecure-skip-tls-verify --server=https://{vm_ip}:6443"
    ssh_baremetal(f"mkdir -p {crypto}")
    for secret, ns, dest in [
        ("loadbalancer-serving-signer", "openshift-kube-apiserver-operator", "lb-signer.key"),
        ("localhost-serving-signer", "openshift-kube-apiserver-operator", "localhost-signer.key"),
        ("service-network-serving-signer", "openshift-kube-apiserver-operator", "service-network-signer.key"),
        ("router-ca", "openshift-ingress-operator", "ingress.key"),
    ]:
        ssh_baremetal(f"{oc} extract secret/{secret} -n {ns} --keys=tls.key --to=- > {crypto}/{dest}")
    ssh_baremetal(f"{oc} extract configmap/admin-kubeconfig-client-ca -n openshift-config --keys=ca-bundle.crt --to=- > {crypto}/admin-kubeconfig-client-ca.crt")
    ingress_cn = ssh_baremetal(
        f"{oc} get secret/router-ca -n openshift-ingress-operator "
        f"-o jsonpath='{{.data.tls\\.crt}}' | base64 -d | openssl x509 -noout -subject | sed 's/subject=CN *= *//'")
    if not ingress_cn.stdout.strip():
        sys.exit("Failed to extract ingress operator CN")
    ssh_baremetal(f"echo '{ingress_cn.stdout.strip()}' > {crypto}/ingress-cn.txt")
    ssh_baremetal(f"rm -f {temp_kc}")
    print_step(2, 6, "Extracting crypto keys", "done")

    print_step(3, 6, "Shutting down VM")
    ssh_baremetal(f"virsh shutdown {vm_name}")
    for _ in range(60):
        r = ssh_baremetal(f"virsh domstate {vm_name}")
        if "shut off" in r.stdout:
            break
        time.sleep(2)
    else:
        sys.exit("VM did not shut down in 2 minutes")
    print_step(3, 6, "Shutting down VM", "done")

    print_step(4, 6, "Creating directories")
    ssh_baremetal(f"mkdir -p {fdir} {REMOTE_OVERLAYS}")
    print_step(4, 6, "Creating directories", "done")

    print_step(5, 6, f"Copying {len(disks)} disk(s)")
    for i, disk in enumerate(disks):
        dest = f"{fdir}/disk-{i}.qcow2"
        ssh_baremetal(f"cp --sparse=always {disk['path']} {dest}")
        ssh_baremetal(f"chown qemu:qemu {dest}")
    print_step(5, 6, f"Copying {len(disks)} disk(s)", "done")

    print_step(6, 6, "Restarting source VM")
    ssh_baremetal(f"virsh start {vm_name}")
    print_step(6, 6, "Restarting source VM", "done")

    with locked_state() as state:
        state["flavors"][flavor_name] = {
            "source_cluster": source_id,
            "source_primary_subnet": src_primary_subnet,
            "source_secondary_subnet": src_secondary_subnet,
            "memory_kib": dominfo["memory_kib"],
            "vcpus": dominfo["vcpus"],
            "disks": [f"disk-{i}.qcow2" for i in range(len(disks))],
            "etcd_image": etcd_image,
            "created_at": datetime.now(timezone.utc).isoformat(),
        }
    print(f"\nFlavor '{flavor_name}' created at {fdir}")


def cmd_boot(args):
    with locked_state() as state:
        flavors = state["flavors"]
        if not flavors:
            sys.exit("No flavors available. Run 'cluster-tool snapshot --name NAME --source ID' first.")

        flavor_name = args.flavor
        if not flavor_name:
            flavor_name = max(flavors, key=lambda k: flavors[k]["created_at"])
        if flavor_name not in flavors:
            sys.exit(f"Flavor '{flavor_name}' not found. Available: {', '.join(flavors.keys())}")

        flavor = flavors[flavor_name]
        source_id = flavor["source_cluster"]
        src_primary = flavor["source_primary_subnet"]
        src_secondary = flavor["source_secondary_subnet"]
        memory_kib = flavor["memory_kib"]
        vcpus = flavor["vcpus"]
        etcd_image = flavor["etcd_image"]
        disk_names = flavor["disks"]
        fdir = flavor_dir(flavor_name)
        crypto = flavor_crypto_dir(flavor_name)

        clone_id = args.name or generate_clone_id()
        if clone_id in state["clones"]:
            sys.exit(f"Clone '{clone_id}' already exists.")

        subnet = allocate_subnet(state)

    subnet_sec = subnet + SUBNET_SECONDARY_OFFSET
    mac1, mac2 = generate_mac(), generate_mac()
    vm_ip = f"192.168.{subnet}.{VM_IP_SUFFIX}"
    vm_name = f"test-infra-cluster-{clone_id}-master-0"
    domain = f"test-infra-cluster-{clone_id}.redhat.com"

    total = 9
    print(f'Creating clone "{clone_id}"...')
    cleanup = []

    try:
        print_step(1, total, f"Creating {len(disk_names)} disk overlay(s)")
        overlays = []
        for disk_name in disk_names:
            overlay = f"{REMOTE_OVERLAYS}/{clone_id}-{disk_name}"
            ssh_baremetal(f"qemu-img create -f qcow2 -b {fdir}/{disk_name} -F qcow2 {overlay}")
            ssh_baremetal(f"chown qemu:qemu {overlay}")
            cleanup.append(("rm", overlay))
            overlays.append(overlay)
        print_step(1, total, f"Creating {len(disk_names)} disk overlay(s)", "done")

        print_step(2, total, f"Creating network 192.168.{subnet}.0/24")
        primary_xml = gen_primary_network_xml(clone_id, subnet, mac1)
        secondary_xml = gen_secondary_network_xml(clone_id, subnet, subnet_sec, mac2)
        write_remote_file(f"/tmp/net-{clone_id}.xml", primary_xml)
        ssh_baremetal(f"virsh net-define /tmp/net-{clone_id}.xml")
        cleanup.append(("net", f"test-infra-net-{clone_id}"))
        ssh_baremetal(f"virsh net-start test-infra-net-{clone_id}")
        write_remote_file(f"/tmp/snet-{clone_id}.xml", secondary_xml)
        ssh_baremetal(f"virsh net-define /tmp/snet-{clone_id}.xml")
        cleanup.append(("net", f"test-infra-secondary-network-{clone_id}"))
        ssh_baremetal(f"virsh net-start test-infra-secondary-network-{clone_id}")
        ssh_baremetal(f"rm -f /tmp/net-{clone_id}.xml /tmp/snet-{clone_id}.xml")
        print_step(2, total, f"Creating network 192.168.{subnet}.0/24", "done")

        print_step(3, total, "Booting VM")
        vm_xml = gen_vm_xml(clone_id, overlays, mac1, mac2, memory_kib=memory_kib, vcpus=vcpus)
        write_remote_file(f"/tmp/vm-{clone_id}.xml", vm_xml)
        ssh_baremetal(f"virsh define /tmp/vm-{clone_id}.xml")
        ssh_baremetal(f"virsh start {vm_name}")
        cleanup.append(("vm", vm_name))
        ssh_baremetal(f"rm -f /tmp/vm-{clone_id}.xml")
        print_step(3, total, "Booting VM", "done")

        print_step(4, total, "Waiting for SSH")
        for _ in range(60):
            if ssh_vm(vm_ip, "echo ready", check=False).returncode == 0:
                break
            time.sleep(5)
        else:
            sys.exit("SSH not available after 5 minutes")
        print_step(4, total, "Waiting for SSH", "done")

        print_step(5, total, "Running recert")
        src_ip = f"192.168.{src_primary}.{VM_IP_SUFFIX}"
        src_sec_ip = f"192.168.{src_secondary}.{VM_IP_SUFFIX}"
        new_sec_ip = f"192.168.{subnet_sec}.{VM_IP_SUFFIX}"

        ssh_vm(vm_ip, "sudo systemctl stop kubelet")
        time.sleep(5)
        ssh_vm(vm_ip, "sudo systemctl stop crio")
        time.sleep(5)

        ssh_baremetal(f"scp {' '.join(SSH_OPTS)} -r {crypto} core@{vm_ip}:/tmp/crypto")
        ingress_cn = ssh_baremetal(f"cat {crypto}/ingress-cn.txt").stdout.strip()

        ssh_vm(vm_ip,
            f"sudo podman run -d --name etcd-recert "
            f"--network host --privileged "
            f"-v /var/lib/etcd:/var/lib/etcd "
            f"{etcd_image} "
            f"--data-dir /var/lib/etcd "
            f"--listen-client-urls http://localhost:2379 "
            f"--advertise-client-urls http://localhost:2379 "
            f"--listen-peer-urls http://localhost:2380 "
            f"--force-new-cluster")

        for _ in range(30):
            r = ssh_vm(vm_ip, "curl -sf http://localhost:2379/health 2>/dev/null", check=False)
            if r.returncode == 0:
                break
            time.sleep(2)
        else:
            logs = ssh_vm(vm_ip, "sudo podman logs etcd-recert 2>&1 | tail -20", check=False)
            sys.exit(f"Standalone etcd not healthy after 60s.\n{logs.stdout}")

        ssh_vm(vm_ip,
            f"sudo podman run --rm --name recert "
            f"--pull=newer "
            f"--network host --privileged "
            f"-v /etc/kubernetes:/etc/kubernetes "
            f"-v /var/lib/kubelet:/var/lib/kubelet "
            f"-v /etc/machine-config-daemon:/etc/machine-config-daemon "
            f"-v /etc/cni:/etc/cni "
            f"-v /tmp/crypto:/tmp/crypto:ro "
            f"{RECERT_IMAGE} "
            f"--etcd-endpoint localhost:2379 "
            f"--crypto-dir /etc/kubernetes "
            f"--crypto-dir /var/lib/kubelet "
            f"--crypto-dir /etc/machine-config-daemon "
            f"--crypto-dir /etc/cni "
            f"--cluster-customization-dir /etc/kubernetes "
            f"--cluster-customization-dir /var/lib/kubelet "
            f"--cluster-customization-dir /etc/machine-config-daemon "
            f"--use-key kube-apiserver-lb-signer:/tmp/crypto/lb-signer.key "
            f"--use-key kube-apiserver-localhost-signer:/tmp/crypto/localhost-signer.key "
            f"--use-key kube-apiserver-service-network-signer:/tmp/crypto/service-network-signer.key "
            f"--use-key {ingress_cn}:/tmp/crypto/ingress.key "
            f"--cluster-rename test-infra-cluster-{clone_id}:redhat.com "
            f"--hostname {vm_name} "
            f"--ip {vm_ip} "
            f"--cn-san-replace api.test-infra-cluster-{source_id}.redhat.com:api.{domain} "
            f"--cn-san-replace api-int.test-infra-cluster-{source_id}.redhat.com:api-int.{domain} "
            f"--cn-san-replace *.apps.test-infra-cluster-{source_id}.redhat.com:*.apps.{domain} "
            f"--cn-san-replace test-infra-cluster-{source_id}-master-0:{vm_name} "
            f"--cn-san-replace system:node:test-infra-cluster-{source_id}-master-0,system:node:{vm_name} "
            f"--cn-san-replace {src_ip}:{vm_ip} "
            f"--cn-san-replace {src_sec_ip}:{new_sec_ip}")

        ssh_vm(vm_ip, "sudo podman stop etcd-recert && sudo podman rm etcd-recert")

        node_fix = (
            f"import pathlib\n"
            f"pathlib.Path('/etc/default/sno_dnsmasq_configuration_overrides').write_text("
            f"'SNO_CLUSTER_NAME_OVERRIDE=test-infra-cluster-{clone_id}\\n"
            f"SNO_BASE_DOMAIN_OVERRIDE=redhat.com\\n"
            f"SNO_DNSMASQ_IP_OVERRIDE={vm_ip}\\n')\n"
            f"pathlib.Path('/etc/default/nodeip-configuration').write_text("
            f"'KUBELET_NODEIP_HINT=192.168.{subnet}.0\\n')\n"
            f"import subprocess\n"
            f"subprocess.run(['hostnamectl', 'set-hostname', '{vm_name}'], check=True)\n"
            f"import shutil\n"
            f"shutil.rmtree('/run/nodeip-configuration', ignore_errors=True)\n"
            f"subprocess.run(['systemctl', 'restart', 'nodeip-configuration'], check=True)\n"
            f"subprocess.run(['systemctl', 'daemon-reload'], check=True)\n"
            f"subprocess.run(['systemctl', 'restart', 'NetworkManager'], check=True)\n"
            f"subprocess.run(['systemctl', 'restart', 'dnsmasq'], check=True)\n"
        )
        fix_b64 = base64.b64encode(node_fix.encode()).decode()
        ssh_vm(vm_ip, f"echo {fix_b64} | base64 -d | sudo python3")

        ssh_vm(vm_ip, "sudo systemctl start crio")
        time.sleep(3)
        ssh_vm(vm_ip, "sudo systemctl start kubelet")
        print_step(5, total, "Running recert", "done")

        print_step(6, total, "Waiting for cluster health")
        for _ in range(120):
            r = ssh_baremetal(f"curl -sk https://{vm_ip}:6443/healthz", check=False)
            if r.stdout.strip() == "ok":
                break
            time.sleep(5)
        else:
            sys.exit("Cluster not healthy after 10 minutes")
        print_step(6, total, "Waiting for cluster health", "done")

        print_step(7, total, "Configuring access")
        kubeconfig_path = KUBECONFIG_DIR / f"{clone_id}.kubeconfig"
        KUBECONFIG_DIR.mkdir(parents=True, exist_ok=True)
        r = ssh_vm(vm_ip, "sudo cat /etc/kubernetes/static-pod-resources/kube-apiserver-certs/secrets/node-kubeconfigs/lb-ext.kubeconfig")
        kubeconfig_path.write_text(r.stdout)

        kc_content = kubeconfig_path.read_text()
        kc_content = kc_content.replace(f"https://{vm_ip}:6443", f"https://api.{domain}:6443")
        kubeconfig_path.write_text(kc_content)
        cleanup.append(("kubeconfig", kubeconfig_path))

        add_haproxy_clone(clone_id, subnet)
        cleanup.append(("haproxy", clone_id))
        add_dns_entry(clone_id)
        cleanup.append(("dns", clone_id))
        print_step(7, total, "Configuring access", "done")

        print(f"\n  Kubeconfig available at: {kubeconfig_path}")
        print(f"  export KUBECONFIG={kubeconfig_path}\n")

        print_step(8, total, "Waiting for operators")
        kc_path = "/etc/kubernetes/static-pod-resources/kube-apiserver-certs/secrets/node-kubeconfigs/lb-ext.kubeconfig"
        oc_vm = f"sudo oc --kubeconfig={kc_path} --insecure-skip-tls-verify"
        node_ready = False
        for _ in range(60):
            r = ssh_vm(vm_ip, f"{oc_vm} get nodes -o json", check=False)
            if r.returncode == 0:
                try:
                    nodes = json.loads(r.stdout)
                    for node in nodes["items"]:
                        for cond in node["status"]["conditions"]:
                            if cond["type"] == "Ready" and cond["status"] == "True":
                                node_ready = True
                except (json.JSONDecodeError, KeyError):
                    pass
            if node_ready:
                break
            time.sleep(5)
        else:
            r = ssh_vm(vm_ip, f"{oc_vm} get nodes -o wide", check=False)
            sys.exit(f"Node not Ready after 5 minutes.\n{r.stdout}\n{r.stderr}")
        last_unhealthy = []
        for attempt in range(120):
            r = ssh_vm(vm_ip, f"{oc_vm} get co -o json", check=False)
            if r.returncode == 0:
                try:
                    cos = json.loads(r.stdout)
                    items = cos["items"]
                    if items:
                        last_unhealthy = []
                        for co in items:
                            name = co["metadata"]["name"]
                            conds = {c["type"]: c["status"] for c in co["status"]["conditions"]}
                            if conds.get("Available") != "True" or conds.get("Degraded") == "True":
                                msg = next((c.get("message", "") for c in co["status"]["conditions"] if c["type"] == "Degraded" and c["status"] == "True"), "")
                                if not msg:
                                    msg = next((c.get("message", "") for c in co["status"]["conditions"] if c["type"] == "Available" and c["status"] != "True"), "")
                                last_unhealthy.append(f"{name}: {msg[:120]}")
                        if not last_unhealthy:
                            break
                except json.JSONDecodeError:
                    pass
            time.sleep(10)
        else:
            detail = "\n".join(f"  - {u}" for u in last_unhealthy)
            sys.exit(f"Operators not healthy after 20 minutes.\nUnhealthy operators:\n{detail}")
        print_step(8, total, "Waiting for operators", f"done ({len(items)}/{len(items)})")

        print_step(9, total, "Verifying cluster identity")
        verify_cluster_identity(vm_ip, clone_id, domain)
        print_step(9, total, "Verifying cluster identity", "done")

    except (SystemExit, subprocess.CalledProcessError) as e:
        print(f"\nBoot failed, rolling back...")
        for kind, target in reversed(cleanup):
            if kind == "vm":
                destroy_vm(target)
            elif kind == "net":
                ssh_baremetal(f"virsh net-destroy {target}")
                ssh_baremetal(f"virsh net-undefine {target}")
            elif kind == "rm":
                ssh_baremetal(f"rm -f {target}")
            elif kind == "kubeconfig":
                target.unlink(missing_ok=True)
            elif kind == "haproxy":
                remove_haproxy_clone(target)
            elif kind == "dns":
                remove_dns_entry(target)
        print("Rollback complete.")
        if isinstance(e, subprocess.CalledProcessError):
            sys.exit(f"Command failed: {e.cmd}\n{e.stderr or e.stdout or ''}")
        raise

    with locked_state() as state:
        state["clones"][clone_id] = {
            "flavor": flavor_name,
            "subnet_primary": subnet,
            "subnet_secondary": subnet_sec,
            "vm_name": vm_name,
            "overlay_disks": overlays,
            "mac_primary": mac1,
            "mac_secondary": mac2,
            "created_at": datetime.now(timezone.utc).isoformat(),
        }

    print(f'\nCluster "{clone_id}" ready!')
    print(f"  API:        https://api.{domain}:6443")
    print(f"  Console:    https://console-openshift-console.apps.{domain}")
    print(f"  Kubeconfig: {kubeconfig_path}")
    print(f"\nexport KUBECONFIG={kubeconfig_path}")


def cmd_list(args):
    state = load_state()
    clones = state["clones"]
    if not clones:
        print("No clones running.")
        return
    print(f"{'NAME':<14s} {'FLAVOR':<15s} {'SUBNET':<22s} {'CREATED'}")
    print("-" * 70)
    for cid, info in clones.items():
        subnet = f"192.168.{info['subnet_primary']}.0/24"
        print(f"{cid:<14s} {info['flavor']:<15s} {subnet:<22s} {info['created_at'][:19]}")


def cmd_verify(args):
    state = load_state()
    clone_id = args.name
    if clone_id not in state["clones"]:
        sys.exit(f"Clone '{clone_id}' not found.")

    info = state["clones"][clone_id]
    vm_ip = f"192.168.{info['subnet_primary']}.{VM_IP_SUFFIX}"
    kubeconfig_path = KUBECONFIG_DIR / f"{clone_id}.kubeconfig"
    if not kubeconfig_path.exists():
        sys.exit(f"Kubeconfig not found at {kubeconfig_path}")

    print(f'Verifying clone "{clone_id}"...')
    kc = f"/etc/kubernetes/static-pod-resources/kube-apiserver-certs/secrets/node-kubeconfigs/lb-ext.kubeconfig"
    oc_vm = f"sudo oc --kubeconfig={kc} --insecure-skip-tls-verify"
    ns = f"smoke-test-{clone_id}"

    print_step(1, 4, "Checking operators")
    r = ssh_vm(vm_ip, f"{oc_vm} get co -o json")
    cos = json.loads(r.stdout)
    unhealthy = []
    for co in cos["items"]:
        name = co["metadata"]["name"]
        conds = {c["type"]: c["status"] for c in co["status"]["conditions"]}
        if conds.get("Available") != "True" or conds.get("Degraded") == "True":
            unhealthy.append(name)
    if unhealthy:
        print_step(1, 4, "Checking operators", f"WARN: {len(unhealthy)} unhealthy")
        for u in unhealthy:
            print(f"    - {u}")
    else:
        print_step(1, 4, "Checking operators", f"done ({len(cos['items'])}/{len(cos['items'])})")

    print_step(2, 4, "Deploying smoke test pod")
    ssh_vm(vm_ip, f"{oc_vm} create namespace {ns} 2>/dev/null", check=False)
    smoke_cmd = (
        "nslookup kubernetes.default.svc.cluster.local > /dev/null 2>&1 && "
        "echo DNS_CLUSTER=OK || echo DNS_CLUSTER=FAIL; "
        "nslookup redhat.com > /dev/null 2>&1 && "
        "echo DNS_EXTERNAL=OK || echo DNS_EXTERNAL=FAIL; "
        "curl -sf --cacert /var/run/secrets/kubernetes.io/serviceaccount/ca.crt "
        "-H \"Authorization: Bearer $(cat /var/run/secrets/kubernetes.io/serviceaccount/token)\" "
        "https://kubernetes.default.svc/api?timeout=5s > /dev/null 2>&1 && "
        "echo API_ACCESS=OK || echo API_ACCESS=FAIL; "
        "echo SMOKE_DONE"
    )
    ssh_vm(vm_ip,
        f"{oc_vm} run smoke-test -n {ns} --restart=Never "
        f"--image=registry.access.redhat.com/ubi9/ubi-minimal:latest "
        f"--command -- sh -c \"{smoke_cmd}\"")
    print_step(2, 4, "Deploying smoke test pod", "done")

    print_step(3, 4, "Waiting for smoke test")
    for _ in range(30):
        r = ssh_vm(vm_ip, f"{oc_vm} get pod smoke-test -n {ns} -o jsonpath='{{.status.phase}}'")
        if r.stdout.strip() in ("Succeeded", "Failed"):
            break
        time.sleep(5)
    else:
        ssh_vm(vm_ip, f"{oc_vm} delete namespace {ns}")
        sys.exit("Smoke test pod did not complete in 2.5 minutes")

    logs = ssh_vm(vm_ip, f"{oc_vm} logs smoke-test -n {ns}").stdout
    ssh_vm(vm_ip, f"{oc_vm} delete namespace {ns}")
    print_step(3, 4, "Waiting for smoke test", "done")

    print_step(4, 4, "Results")
    results = {}
    for line in logs.strip().split("\n"):
        if "=" in line:
            k, v = line.strip().split("=", 1)
            results[k] = v
    all_ok = all(v == "OK" for k, v in results.items() if k != "SMOKE_DONE")
    for k, v in results.items():
        if k != "SMOKE_DONE":
            status = "PASS" if v == "OK" else "FAIL"
            print(f"    {k}: {status}")
    if all_ok and "SMOKE_DONE" in results:
        print_step(4, 4, "Results", "ALL PASSED")
    else:
        print_step(4, 4, "Results", "SOME FAILED")
        sys.exit(1)


def cmd_flavors(args):
    if args.delete:
        name = args.delete
        with locked_state() as state:
            if name not in state["flavors"]:
                sys.exit(f'Flavor "{name}" not found.')
            ssh_baremetal(f"rm -rf {flavor_dir(name)}")
            del state["flavors"][name]
            print(f'Flavor "{name}" deleted.')
        return
    state = load_state()
    flavors = state["flavors"]
    if not flavors:
        print("No flavors available. Run 'cluster-tool snapshot --name NAME --source CLUSTER_ID' to create one.")
        return
    print(f"{'NAME':<20s} {'SOURCE':<12s} {'RAM':<8s} {'CPU':<6s} {'DISKS':<6s} {'CREATED'}")
    print("-" * 80)
    for name, info in flavors.items():
        ram = f"{info['memory_kib'] // 1024 // 1024}GB"
        print(f"{name:<20s} {info['source_cluster']:<12s} {ram:<8s} {str(info['vcpus']):<6s} {str(len(info['disks'])):<6s} {info['created_at'][:19]}")


def cmd_destroy(args):
    state = load_state()
    if args.all:
        ids = list(state["clones"].keys())
        if not ids:
            print("No clones to destroy.")
            return
    elif args.name:
        ids = [args.name]
    else:
        sys.exit("Specify a clone name or --all")

    for cid in ids:
        vm = f"test-infra-cluster-{cid}-master-0"
        print(f'Destroying clone "{cid}"...')

        destroy_vm(vm)
        ssh_baremetal(f"virsh net-destroy test-infra-net-{cid}", check=False)
        ssh_baremetal(f"virsh net-undefine test-infra-net-{cid}", check=False)
        ssh_baremetal(f"virsh net-destroy test-infra-secondary-network-{cid}", check=False)
        ssh_baremetal(f"virsh net-undefine test-infra-secondary-network-{cid}", check=False)
        ssh_baremetal(f"rm -f {REMOTE_OVERLAYS}/{cid}-*.qcow2")

        remove_haproxy_clone(cid)
        remove_dns_entry(cid)
        (KUBECONFIG_DIR / f"{cid}.kubeconfig").unlink(missing_ok=True)

        with locked_state() as s:
            s["clones"].pop(cid, None)
        print(f'Clone "{cid}" destroyed.')


def main():
    parser = argparse.ArgumentParser(description="Snapshot-based SNO cluster cloning")
    sub = parser.add_subparsers(dest="command")

    snap_p = sub.add_parser("snapshot", help="Create a named snapshot flavor from a running cluster")
    snap_p.add_argument("--name", required=True, help="Flavor name (e.g., sno-64, sno-cnv)")
    snap_p.add_argument("--source", required=True, help="Source cluster ID (8 hex chars from VM name)")

    boot_p = sub.add_parser("boot", help="Boot a fresh cluster from a snapshot flavor")
    boot_p.add_argument("--flavor", help="Flavor to boot from (default: most recent)")
    boot_p.add_argument("--name", help="Clone ID (random if omitted)")

    sub.add_parser("list", help="Show running clones")

    flavors_p = sub.add_parser("flavors", help="List or manage snapshot flavors")
    flavors_p.add_argument("--delete", metavar="NAME", help="Delete a flavor")

    verify_p = sub.add_parser("verify", help="Run smoke tests on a clone")
    verify_p.add_argument("name", help="Clone ID to verify")

    destroy_p = sub.add_parser("destroy", help="Tear down a clone")
    destroy_p.add_argument("name", nargs="?", help="Clone ID to destroy")
    destroy_p.add_argument("--all", action="store_true", help="Destroy all clones")

    args = parser.parse_args()
    cmds = {"snapshot": cmd_snapshot, "boot": cmd_boot, "list": cmd_list, "flavors": cmd_flavors, "verify": cmd_verify, "destroy": cmd_destroy}

    if args.command not in cmds:
        parser.print_help()
        sys.exit(1)
    cmds[args.command](args)


if __name__ == "__main__":
    main()
