class ExecutionEnv:
    def __init__(self, *, host, host_ip):
        self.host = host
        self.host_ip = host_ip
        self.is_local = (host == "local")

    def run(self, cmd, *, check=True):
        if self.is_local:
            r = subprocess.run(cmd, shell=True, capture_output=True, text=True)
        else:
            r = subprocess.run(
                ["ssh"] + SSH_OPTS + [self.host, cmd],
                capture_output=True, text=True,
            )
        if check and r.returncode != 0:
            sys.exit(f"Command failed (exit {r.returncode}): {cmd}\n{r.stderr.strip()}")
        return r

    def run_vm(self, vm_ip, cmd, *, check=True, identity=None):
        id_opts = ["-i", identity] if identity else []
        if self.is_local:
            r = subprocess.run(
                ["ssh"] + SSH_OPTS + id_opts + [f"core@{vm_ip}", cmd],
                capture_output=True, text=True,
            )
            if check and r.returncode != 0:
                sys.exit(f"SSH command failed (exit {r.returncode}): {cmd}\n{r.stderr.strip()}")
            return r
        id_flag = f"-i {identity} " if identity else ""
        jump = f"ssh {' '.join(SSH_OPTS)} {id_flag}core@{vm_ip} '{cmd}'"
        return self.run(jump, check=check)

    def copy_from(self, remote_path, local_path):
        if self.is_local:
            subprocess.run(["cp", str(remote_path), str(local_path)], check=True)
        else:
            subprocess.run(
                ["scp"] + SSH_OPTS + [f"{self.host}:{remote_path}", str(local_path)],
                capture_output=True, text=True, check=True,
            )

    def write_file(self, path, content):
        if self.is_local:
            Path(path).parent.mkdir(parents=True, exist_ok=True)
            Path(path).write_text(content)
        else:
            encoded = base64.b64encode(content.encode()).decode()
            self.run(f"echo '{encoded}' | base64 -d > {path}")


env = None


def build_manifest(*, flavor_name, metadata, disk_names):
    return {
        "version": 1,
        "flavor": flavor_name,
        "disks": [{"name": d, "prefix": d.replace(".qcow2", "")} for d in disk_names],
        "metadata": metadata,
    }


def parse_manifest(raw):
    manifest = json.loads(raw) if isinstance(raw, str) else raw
    for key in ("version", "flavor", "disks", "metadata"):
        if key not in manifest:
            sys.exit(f"Invalid manifest: missing '{key}'")
    for disk in manifest["disks"]:
        if "name" not in disk or "prefix" not in disk:
            sys.exit(f"Invalid manifest: disk entry missing 'name' or 'prefix'")
    return manifest


