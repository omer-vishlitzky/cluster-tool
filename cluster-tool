def print_step(num, total, desc, status=""):
    if status:
        print(f"\r  [{num}/{total}] {desc:<40s} {status}")
    else:
        print(f"  [{num}/{total}] {desc:<40s}", end="", flush=True)


def destroy_vm(vm_name):
    r = env.run(f"virsh domstate {vm_name}", check=False)
    if r.returncode != 0:
        return
    if "shut off" in r.stdout:
        env.run(f"virsh undefine {vm_name}")
        return
    env.run(f"virsh destroy {vm_name}")
    env.run(f"virsh undefine {vm_name}")


def _strip_haproxy_clone(config, clone_id):
    backend_names = {f"api-{clone_id}", f"ingress-https-{clone_id}", f"ingress-http-{clone_id}"}
    lines = config.split("\n")
    filtered = []
    skip_block = False
    for line in lines:
        if "use_backend" in line:
            parts = line.split()
            idx = parts.index("use_backend") if "use_backend" in parts else -1
            if idx >= 0 and idx + 1 < len(parts) and parts[idx + 1] in backend_names:
                continue
        if line.strip().startswith("backend "):
            name = line.strip().split()[1]
            if name in backend_names:
                skip_block = True
                continue
        if skip_block:
            if line.strip() and not line.strip().startswith("backend") and not line.strip().startswith("frontend"):
                continue
            skip_block = False
            if not line.strip():
                continue
        filtered.append(line)
    return "\n".join(filtered)


def add_haproxy_clone(clone_id, subnet):
    with locked_haproxy():
        use_backends, backends = gen_haproxy_additions(clone_id, subnet)
        result = env.run("cat /etc/haproxy/haproxy.cfg")
        config = _strip_haproxy_clone(result.stdout, clone_id)

        for key in ["api", "ingress-https", "ingress-http"]:
            marker = f"    default_backend {key}-"
            config = config.replace(marker, f"{use_backends[key]}\n\n{marker}", 1)

        config = config.rstrip() + "\n" + backends
        env.write_file("/etc/haproxy/haproxy.cfg", config)
        env.run("systemctl reload haproxy")


def remove_haproxy_clone(clone_id):
    with locked_haproxy():
        result = env.run("cat /etc/haproxy/haproxy.cfg")
        config = _strip_haproxy_clone(result.stdout, clone_id)
        env.write_file("/etc/haproxy/haproxy.cfg", config)
        env.run("systemctl reload haproxy")


